      <aliases enabled='yes' />
      <column caption='Passed' datatype='integer' name='[Calculation_2651775781433090048]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT([Test_Result] = &quot;Pass&quot;)' />
      </column>
      <column caption='Pass Rate' datatype='real' datatype-customized='true' name='[Calculation_2651775781434306561]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_2651775781433090048]) / COUNT([Control_ID])' />
      </column>
      <column caption='Is Deficient' datatype='boolean' name='[Calculation_2651775781434470402]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Test_Result] = &quot;Exception&quot; OR [Test_Result] = &quot;Fail&quot;' />
      </column>
      <column caption='Days Overdue' datatype='integer' name='[Calculation_2651775781438210051]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Remediation_Status] &lt;&gt; &quot;Closed&quot; AND NOT ISNULL([Remediation_Due_Date])&#13;&#10;THEN DATEDIFF(&apos;day&apos;, [Remediation_Due_Date], [Parameters].[Assertion Parameter])&#13;&#10;END' />
      </column>
      <column caption='Is Overdue' datatype='boolean' name='[Calculation_2651775781438607364]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_2651775781438210051] &gt; 0' />
      </column>
      <column caption='Exception Rate' datatype='real' name='[Calculation_2651775781438722053]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Exceptions_Noted]) / SUM([Sample_Size])' />
      </column>
      <column caption='Control Description' datatype='string' name='[Control_Description]' role='dimension' type='nominal' />
      <column caption='Control ID' datatype='string' name='[Control_ID]' role='dimension' type='nominal' />
      <column caption='Control Nature' datatype='string' name='[Control_Nature]' role='dimension' type='nominal' />
      <column caption='Control Owner' datatype='string' name='[Control_Owner]' role='dimension' type='nominal' />
      <column caption='Control Type' datatype='string' name='[Control_Type]' role='dimension' type='nominal' />
      <column caption='Deficiency Severity' datatype='string' name='[Deficiency_Severity]' role='dimension' type='nominal' />
      <column caption='Deficiency Type' datatype='string' name='[Deficiency_Type]' role='dimension' type='nominal' />
      <column caption='Exceptions Noted' datatype='integer' name='[Exceptions_Noted]' role='measure' type='quantitative' />
      <column caption='Population Size' datatype='integer' name='[Population_Size]' role='measure' type='quantitative' />
      <column caption='Remediation Due Date' datatype='date' name='[Remediation_Due_Date]' role='dimension' type='ordinal' />
      <column caption='Remediation Owner' datatype='string' name='[Remediation_Owner]' role='dimension' type='nominal' />
      <column caption='Remediation Status' datatype='string' name='[Remediation_Status]' role='dimension' type='nominal' />
      <column caption='Risk Description' datatype='string' name='[Risk_Description]' role='dimension' type='nominal' />
      <column caption='Risk ID' datatype='string' name='[Risk_ID]' role='dimension' type='nominal' />
      <column caption='Sample Size' datatype='integer' name='[Sample_Size]' role='measure' type='quantitative' />
      <column caption='Test Date' datatype='date' name='[Test_Date]' role='dimension' type='ordinal' />
      <column caption='Test Procedure' datatype='string' name='[Test_Procedure]' role='dimension' type='nominal' />
      <column caption='Test Result' datatype='string' name='[Test_Result]' role='dimension' type='nominal' />
      <column caption='icfr_control_testing_data.csv' datatype='table' name='[__tableau_internal_object_id__].[icfr_control_testing_data.csv_9EB1F8E486574D5CA8A4991BEB46BC8E]' role='measure' type='quantitative' />
      <column-instance column='[Test_Result]' derivation='None' name='[none:Test_Result:nk]' pivot='key' type='nominal' />
      <layout dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:Test_Result:nk]' type='palette'>
            <map to='#59a14f'>
              <bucket>&quot;Pass&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;Fail&quot;</bucket>
            </map>
            <map to='#edc948'>
              <bucket>&quot;Exception&quot;</bucket>
            </map>
